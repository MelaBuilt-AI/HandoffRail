  "alerting": {
    "alertmanager": "default",
    "rules": [
      {
        "uid": "alert_high_error_rate",
        "title": "HandoffRail — High Error Rate",
        "condition": "A",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 300,
              "to": 0
            },
            "datasourceUid": "${DS_PROMETHEUS}",
            "model": {
              "expr": "(sum(rate(handoffrail_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(handoffrail_requests_total[5m]))) * 100",
              "intervalMs": 30000,
              "maxDataPoints": 100,
              "refId": "A"
            }
          }
        ],
        "noDataState": "OK",
        "execErrState": "Alerting",
        "for": "2m",
        "annotations": {
          "summary": "HTTP 5xx error rate has exceeded 5%",
          "description": "Error rate over the last 5 minutes is {{ $values.A.Value | humanize }}%. Investigate upstream dependencies and server logs."
        },
        "labels": {
          "severity": "critical",
          "team": "backend",
          "service": "handoffrail"
        },
        "ruleGroup": "HandoffRail",
        "evaluationInterval": "1m"
      },
      {
        "uid": "alert_webhook_failure_spike",
        "title": "HandoffRail — Webhook Failure Spike",
        "condition": "A",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 300,
              "to": 0
            },
            "datasourceUid": "${DS_PROMETHEUS}",
            "model": {
              "expr": "(sum(rate(handoffrail_webhook_deliveries_total{result=\"failed\"}[5m])) / sum(rate(handoffrail_webhook_deliveries_total[5m]))) * 100",
              "intervalMs": 30000,
              "maxDataPoints": 100,
              "refId": "A"
            }
          }
        ],
        "noDataState": "OK",
        "execErrState": "Alerting",
        "for": "2m",
        "annotations": {
          "summary": "Webhook delivery failure rate has exceeded 10%",
          "description": "Webhook failure rate over the last 5 minutes is {{ $values.A.Value | humanize }}%. Check webhook endpoint health and network connectivity."
        },
        "labels": {
          "severity": "critical",
          "team": "backend",
          "service": "handoffrail"
        },
        "ruleGroup": "HandoffRail",
        "evaluationInterval": "1m"
      },
      {
        "uid": "alert_queue_depth",
        "title": "HandoffRail — Queue Depth Exceeded",
        "condition": "A",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 300,
              "to": 0
            },
            "datasourceUid": "${DS_PROMETHEUS}",
            "model": {
              "expr": "handoffrail_webhook_dlq_size > 100",
              "intervalMs": 30000,
              "maxDataPoints": 100,
              "refId": "A"
            }
          }
        ],
        "noDataState": "OK",
        "execErrState": "Alerting",
        "for": "1m",
        "annotations": {
          "summary": "Webhook dead-letter queue depth exceeds 100",
          "description": "DLQ size is {{ $values.A.Value | humanize }}. Messages are failing delivery and accumulating. Inspect the webhook delivery service."
        },
        "labels": {
          "severity": "warning",
          "team": "backend",
          "service": "handoffrail"
        },
        "ruleGroup": "HandoffRail",
        "evaluationInterval": "1m"
      }
    ],
    "contactPoints": []
  }
