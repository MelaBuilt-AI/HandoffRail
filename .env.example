# HandoffRail Production Environment
# Copy to .env and customize for your deployment

# ── Core ───────────────────────────────────────
HR_ENVIRONMENT=prod
HR_LOG_LEVEL=info
HR_PORT=8080

# ── Database ───────────────────────────────────
HR_DATABASE_URL=postgresql+asyncpg://handoffrail:handoffrail@db:5432/handoffrail
POSTGRES_USER=handoffrail
POSTGRES_PASSWORD=handoffrail
POSTGRES_DB=handoffrail

# ── Redis ──────────────────────────────────────
HR_REDIS_URL=redis://redis:6379/0

# ── CORS ───────────────────────────────────────
# JSON list of allowed origins, e.g.: ["https://app.example.com"]
HR_CORS_ORIGINS=["*"]